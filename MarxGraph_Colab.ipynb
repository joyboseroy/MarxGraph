# MarxGraph ontology v0.1
# Design principle: DOCUMENTARY facts (author X wrote claim Y in work Z, year W) are
# recorded as ground truth. INTERPRETIVE edges (Mao EXTENDS Lenin on concept C) always
# carry a `perspective` field and confidence. Contradictory edges from different
# perspectives coexist deliberately — the graph is perspectival, not canonical.

entity_types:
  thinker:   {key: slug, attrs: [name, born, died, traditions]}
  work:      {key: work_id, attrs: [author, title, year, tradition, language, source_url, license]}
  concept:   {key: concept_slug, attrs: [label, aliases, first_known_author, first_known_year]}
  claim:     {key: claim_id, attrs: [author, work_id, passage_id, text, concepts, year]}
  tradition: {key: slug, attrs: [label, period, key_thinkers]}

relation_types:
  # documentary (extracted directly from text, low interpretation)
  documentary:
    - MENTIONS            # work/claim mentions concept
    - DEFINES             # claim explicitly defines concept
    - CITES               # explicit reference to another thinker/work
    - RESPONDS_TO         # explicit textual response (named opponent/work)
    - TEMPORALLY_PRECEDES
  # interpretive (requires judgment; always perspectival)
  interpretive:
    - ASSERTS
    - SUPPORTS
    - CRITIQUES
    - REJECTS
    - EXTENDS
    - REFORMULATES
    - NARROWS
    - GENERALIZES
    - APPLIES_TO
    - INFLUENCED_BY

transformation_types:   # for concept_evolution table (concept passing between thinkers)
  - PRESERVED
  - EXTENDED
  - REFORMULATED
  - CONTEXTUALIZED      # adapted to new historical conditions (e.g. peasantry as revolutionary base)
  - CONTESTED
  - REJECTED

perspectives:           # who is making the interpretive judgment
  - llm_extraction      # model-generated, carries model id + confidence
  - human_annotator
  - trotskyist_tradition
  - marxist_leninist_tradition
  - maoist_tradition
  - academic_scholarship

edge_provenance_schema:
  source_author: str
  source_work: str
  year: int
  relation: str
  target: str
  evidence_span: str        # verbatim quote supporting the edge (<= 50 words)
  source_location: str      # work_id + passage_id
  perspective: str
  extraction_method: str    # llm | manual
  model: str                # if llm
  confidence: float
